{
  "private": true,
  "name": "tsc-playground",
  "version": "1.0.0",
  "description": "A playground for the TypeScript Compiler (tsc).",
  "keywords": [
    "Playground",
    "Private"
  ],
  "main": "out/lib/index.js",
  "typings": "out/lib/index.d.ts",
  "scripts": {
    "prebuild": "run-s clean-up",
    "build": "run-s ~~build",
    "prebuild-watch": "run-s prebuild",
    "build-watch": "run-s ~~build-watch",
    "clean-up": "node --eval \"require('shelljs/global'); set('-e'); rm('-rf', 'out/');\"",
    "predev": "run-s build || true",
    "dev": "run-p ~~build-watch ~~run-watch",
    "predev-debug": "run-s predev",
    "dev-debug": "run-p ~~build-watch ~~run-watch-debug",
    "lint": "tslint --project tsconfig.json",
    "pretest": "run-s build",
    "test": "run-s lint && node --print \"require('chalk').default.red('No tests yet :(\\n')\" && exit 1",
    "~~build": "tsc --project ./",
    "~~build-watch": "run-s \"~~build -- --watch\"",
    "~~run": "node ./",
    "~~run-debug": "node --inspect-brk ./",
    "~~run-watch": "node --watch-path=out/ ./",
    "~~run-watch-debug": "node --inspect-brk --watch-path=out/ ./"
  },
  "license": "Unlicense",
  "author": "gkalpak <kalpakas.g@gmail.com>",
  "homepage": "https://github.com/tsc-playground/aliases#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkalpak/tsc-playground.git"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "npm-run-all": "^4.1.5",
    "shelljs": "^0.10.0",
    "tslint": "^6.1.3"
  }
}
